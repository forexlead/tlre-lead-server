# TLRE Backend — Environment Variables
# Set these in Railway → Variables tab

# People Data Labs — peopledatalabs.com
PDL_API_KEY=your_pdl_api_key_here

# SpeedeonData — speedeondata.com (base URL from your onboarding email)
SPEEDEON_API_KEY=your_speedeon_api_key_here
SPEEDEON_BASE_URL=https://api.speedeondata.com

# BatchSkipTracing — batchskiptracing.com (~$0.15/match, no monthly fee)
BST_API_KEY=your_bst_api_key_here

# Wake County + NC eCourts → free, no keys needed

# PORT is set automatically by Railway — do not override
